    "^[%@ contact](inflect: true) can request your telemetry data.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "^[%@ kontakt](inflect: true) může požádat o vaše telemetrická data."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "^[%@ Kontakt](inflect: true) kann Ihre Telemetriedaten anfordern."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "el contacto %@ (inflex: verdadero) puede solicitar tus datos de telemetría."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "[%@ de contact](inflect: true) peut demander vos données télémétriques."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "[%@ contatto](inflect: true) può richiedere i tuoi dati di telemetria."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "^[%@ コンタクト](inflect: true) は、テレメトリー データをリクエストできます。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "[%@ contact](inflect: true) kan uw telemetriegegevens aanvragen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ kontakt(y) (zmień: prawdziwe) może poprosić o dane telemetryczne."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "o contato %@ (%d) pode solicitar seus dados de telemetria."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "[%@ контакт](inflect: true) може запитати ваші дані телеметрії."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 联系人（可变性：true）可以请求您的传感器数据。"
          }
        }
      }
    },
