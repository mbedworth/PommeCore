        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これにより、ラジオは %@ に変更され、BW %@ kHz、SF%@、CR 4/%@ になります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
