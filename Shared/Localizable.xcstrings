    "Outbound path has been reset. A new path will be discovered on next communication.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ausgehender Pfad wurde zurückgesetzt. Beim nächsten Kontakt wird ein neuer Pfad ermittelt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le chemin sortant a été réinitialisé. Un nouveau chemin sera découvert lors de la prochaine communication."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El camino de salida se ha restablecido. Se descubrirá un nuevo camino en la próxima comunicación."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
