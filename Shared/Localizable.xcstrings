    "Select a preset for your region. All nodes on your mesh must use the same settings.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte přednastavenou hodnotu pro vaši oblast. Všechny uzly ve vaší mřížce musí používat stejné nastavení."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie eine Voreinstellung für Ihre Region. Alle Knoten in Ihrem Mesh müssen dieselben Einstellungen verwenden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona una configuración predeterminada para tu región. Todos los nodos de tu red deben usar la misma configuración."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez une bande de fréquence prédéfinie pour votre région. Tous les nœuds de votre maillage doivent utiliser les mêmes paramètres."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Seleziona una preset per la tua regione. Tutti i nodi sulla tua mesh devono utilizzare le stesse impostazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "地域の事前設定を選択。メッシュ上のすべてのノードは同じ設定を使用する必要があります。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een vooraf ingestelde band voor uw regio kiezen. Alle knooppunten in uw mesh moeten dezelfde instellingen gebruiken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz wstępnie ustawioną częstotliwość dla swojego regionu. Wszystkie węzły w twojej siatce muszą używać tych samych ustawień."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecione uma configuração pré-definida para sua região. Todos os nós em sua malha devem usar as mesmas configurações."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть попередньо налаштовану для вашого регіону. Всі вузли у вашій сітці повинні використовувати одні й ті самі налаштування."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为您的区域选择预设。您的网格中的所有节点必须使用相同的设置。"
          }
        }
      }
    },
