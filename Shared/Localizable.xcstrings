    "Scanning temporarily changes your radio settings. Incoming messages may be missed during the scan (%@s total).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Durchführung einer Scan-Operation ändert vorübergehend Ihre Radiokonfigurationen. Während des Scans können eingehende Nachrichten verpasst werden (%@s insgesamt)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La numérisation modifie temporairement les paramètres de votre radio. Les messages entrants pourraient être manqués pendant la numérisation (%@s au total)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La escaneo cambia temporalmente la configuración de tu radio. Los mensajes entrantes podrían perderse durante el escaneo (%@s total)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La scansione modifica temporaneamente le impostazioni della tua radio. I messaggi in entrata potrebbero essere persi durante la scansione (%@s totali)."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het scannen verandert tijdelijk uw radiostelinstellingen. Inkomende berichten kunnen tijdens het scannen worden gemist (%@s in totaal)."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A varredura muda temporariamente as configurações do seu rádio. Mensagens recebidas podem ser perdidas durante a varredura (%@s no total)."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Proskenování dočasně změní nastavení vašeho rádia. Během skenování mohou být zmeškány příchozí zprávy (%@s celkem)."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Skanowanie tymczasowo zmienia ustawienia Twojego radia. Wiadomości przychodzące mogą zostać przeoczone podczas skanowania (%@s łącznie)."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Сканування тимчасово змінює налаштування вашого радіопристрою. Під час сканування можуть бути пропущені вхідні повідомлення (%@s загалом)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スキャンは一時的にラジオ設定を変更します。スキャン中に受信メッセージが失われる可能性があります（%@件）。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "扫描暂时更改您的无线电设置。在扫描期间可能错过传入消息 (%@s 总的)。"
          }
        }
      }
    },
