    "Choose how PommeCore looks. System follows your device’s Dark Mode setting.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Legen Sie fest, wie PommeCore aussieht. System folgt der Dunkel-Modus-Einstellung Ihres Geräts."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez l'apparence de PommeCore. Le système suit les paramètres de mode sombre de votre appareil."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige cómo se ve PommeCore. El sistema sigue la configuración de Modo Oscuro de tu dispositivo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli come PommeCore appare. Il sistema segue le impostazioni del tuo dispositivo per il Dark Mode."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies hoe PommeCore eruit ziet. Het systeem volgt de donkere modusinstelling van je apparaat."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha como o PommeCore parece. O sistema segue a configuração de Modo Escuro do seu dispositivo."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zvolte vzhled PommeCore. Systém sleduje nastavení tmavého režimu vašeho zařízení."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz wygląd PommeCore. System dostosowuje się do ustawień trybu ciemnego Twojego urządzenia."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть, як виглядатиме PommeCore. Система дотримується налаштувань Темного режиму вашого пристрою."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCoreの外観を選択します。システムはデバイスのダークモード設定に従います。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 PommeCore 的外观。系统会遵循您设备的深色模式设置。"
          }
        }
      }
    },
    "Choose which events trigger notifications. In-App Banners shows alerts even when the app is open.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Legen Sie fest, welche Ereignisse Benachrichtigungen auslösen. In-App-Banner zeigt Hinweise auch an, wenn die App geöffnet ist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez quels événements déclenchent des notifications. Les bannières In-App affichent des alertes même lorsque l'application est ouverte."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige qué eventos activan notificaciones. Los Banners In-App muestran alertas incluso cuando la app está abierta."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli quali eventi attivano le notifiche. Gli banner in-app mostrano gli avvisi anche quando l'app è aperta."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies welke gebeurtenissen meldingen activeren. In-App Banners toont waarschuwingen zelfs als de app open is."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha quais eventos acionam notificações. Banners In-App mostram alertas até mesmo quando o app está aberto."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zvolte, jaké události spouštějí oznámení. Oznámení In-App Banners zobrazuje upozornění i při otevřeném aplikaci."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz zdarzenia wyzwalające powiadomienia. Banner w aplikacji wyświetla alerty nawet gdy aplikacja jest otwarta."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть, які події спричинити сповіщення. Банери в додатку показують сповіщення навіть коли додаток відкритий."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通知をトリガーするイベントを選択します。アプリ内バナーは、アプリが開いている場合でもアラートを表示します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择触发通知的事件。应用程序内横幅即使应用打开也会显示提示。"
          }
        }
      }
    },
