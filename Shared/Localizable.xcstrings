    "Device clock is automatically synced from your phone on every connection.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Čas zařízení se automaticky synchronizuje z vašeho telefonu při každém připojení."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Geräteuhr wird bei jeder Verbindung automatisch von Ihrem Telefon synchronisiert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El reloj del dispositivo se sincroniza automáticamente desde tu teléfono en cada conexión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'horloge de l'appareil est automatiquement synchronisée avec votre téléphone à chaque connexion."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'orologio del dispositivo viene sincronizzato automaticamente dal tuo telefono ad ogni connessione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイスの時計は、接続ごとに自動的に電話から同期されます。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het apparaatklok wordt automatisch gesynchroniseerd vanaf je telefoon bij elke verbinding."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zegar urządzenia jest automatycznie synchronizowany z telefonem przy każdej łączności."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O relógio do dispositivo é sincronizado automaticamente com o seu telefone em cada conexão."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Годинник пристрою автоматично синхронізується з вашим телефоном при кожному підключенні."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设备时钟在每次连接时自动从您的手机同步。"
          }
        }
      }
    },
