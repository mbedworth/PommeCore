          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Enviar mensagens, compartilhar canais e conectar-se com outros usando rádio LoRa — sem necessidade de internet ou serviço celular."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Posílejte zprávy, sdílejte kanály a spojujte se s ostatními pomocí rádia LoRa – nepotřebujete internet ani mobilní službu."
