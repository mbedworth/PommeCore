    "Ping and Trace Route require a routed path. Use “Discover Path” or send a message first.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ping und Trace Route erfordern einen gerouteten Pfad. Verwenden Sie „Pfad entdecken“ oder senden Sie zuerst eine Nachricht."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ping et Trace Route nécessitent un chemin routé. Utilisez « Découvrir le chemin » ou envoyez un message d'abord."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ping y Trace Route requieren un camino enrutado. Usa \"Descubrir Ruta\" o envía un mensaje primero."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ping e Trace Route richiedono un percorso instradato. Usa \"Scopri Percorso\" o invia un messaggio prima."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ping en Trace Route vereisen een gerouteerde pad. Gebruik \"Pad Ontdekken\" of stuur eerst een bericht."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ping e Trace Route requerem um caminho roteado. Use \"Descobrir Caminho\" ou envie uma mensagem primeiro."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ping a trasování trasy vyžadují směrovanou cestu. Použijte „Objevit cestu“ nebo nejprve pošlete zprávu."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ping i Trace Route wymagają ścieżki z routowaniem. Użyj \"Odkryj Ścieżkę\" lub wyślij wiadomość najpierw."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ping і Trace Route потребують маршрутизованого шляху. Використовуйте \"Відкрити шлях\" або надішліть повідомлення спочатку."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ピングとトレースルートにはルーティングパスが必要です。\"パスの発見\"またはメッセージの送信を使用してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Ping 和 Trace Route 需要一个路由路径。首先使用“发现路径”或发送消息。"
          }
        }
      }
    },
