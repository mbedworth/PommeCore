    "Requires Apple Watch paired with this iPhone. Messages sync via WatchConnectivity when your iPhone is nearby or reachable.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyžaduje se Apple Watch spárované s tímto iPhonem. Zprávy se synchronizují přes WatchConnectivity, když je váš iPhone poblíž nebo dosažitelný."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfordert eine Apple Watch, die mit diesem iPhone gekoppelt ist. Nachrichten werden über WatchConnectivity synchronisiert, wenn Ihr iPhone in der Nähe ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Requiere Apple Watch emparejado con este iPhone. Los mensajes se sincronizan a través de WatchConnectivity cuando tu iPhone está cerca o es alcanzable."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nécessite une Apple Watch associée à cet iPhone. Les messages sont synchronisés via WatchConnectivity lorsque votre iPhone est proche ou accessible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Richiede Apple Watch abbinato a questo iPhone. I messaggi vengono sincronizzati tramite WatchConnectivity quando il tuo iPhone è nelle vicinanze o raggiungibile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このiPhoneとApple Watchのペアリングが必要です。iPhoneが近くまたは到達可能な場合は、WatchConnectivityを通じてメッセージが同期します。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vereist Apple Watch gekoppeld aan deze iPhone. Berichten worden gesynchroniseerd via WatchConnectivity wanneer je iPhone in de buurt is of bereikbaar."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wymaga Apple Watch sparowanego z tym iPhone'em. Wiadomości synchronizowane są za pośrednictwem WatchConnectivity, gdy iPhone jest w pobliżu lub dostępny."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Requer Apple Watch emparelhado com este iPhone. Mensagens sincronizadas via WatchConnectivity quando o iPhone estiver próximo ou acessível."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вимагає Apple Watch, підключений до цього iPhone. Повідомлення синхронізуються через WatchConnectivity, коли ваш iPhone поруч або доступний."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要与这款 iPhone 配对的 Apple Watch。当你的 iPhone 附近或可访问时，消息将通过 WatchConnectivity 同步。"
          }
        }
      }
    },
    "Resend available in %@s": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Znovu odeslat dostupné %@s"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wieder senden verfügbar in %@s"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reinviar disponible en %@s"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réenvoyer disponible dans %@s"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rinvio disponibile in %@s"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@秒で再送信可能"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hersturen beschikbaar in %@s"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ponowne wysłanie dostępne w %@s"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Reinviar disponível em %@s"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Повторне відправлення доступне %@с"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 %@ 秒后重新发送可用"
          }
        }
      }
    },
    "Resend failed direct messages up to 3 times before marking as failed.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Znovu odeslání selhalo přímé zprávy až třikrát před označením jako selhané."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fehlgeschlagene Direktnachrichten bis zu 3 Mal erneut senden, bevor sie als fehlgeschlagen markiert werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reinviar mensajes fallidos se intentará hasta 3 veces antes de marcar como fallido."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec du réenvoi des messages directs après 3 tentatives."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rinvio fallito: i messaggi diretti verranno ritentati fino a 3 volte prima di essere contrassegnati come falliti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "再送信に失敗した直接メッセージは、3回まで再試行し、失敗とマークされます。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hersturen van directe berichten mislukt; maximaal 3 pogingen voordat het als mislukt wordt gemarkeerd."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ponowne wysłanie wiadomości bezpośrednich nie powiodło się; maksymalnie 3 próby przed oznaczeniem jako nieudane."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Reinviar mensagens diretas falhou. Tenta até 3 vezes antes de marcar como falha."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Повторне відправлення прямого повідомлення не вдалося тричі перед позначенням як невдалого."
