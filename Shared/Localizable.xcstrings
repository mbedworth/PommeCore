    "Connect via USB. If not listed, run 'ls /dev/cu.*' in Terminal and enter the path manually.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Per USB verbinden. Falls nicht aufgelistet, „ls /dev/cu.*‘ im Terminal ausführen und Pfad manuell eingeben."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connectez-vous via USB. Si non répertorié, exécutez 'ls /dev/cu.*' dans le Terminal et entrez le chemin manuellement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conectar vía USB. Si no aparece en la lista, ejecute 'ls /dev/cu.*' en Terminal y ingrese el camino manualmente."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Connetti tramite USB. Se non elencato, esegui 'ls /dev/cu.*' in Terminale e inserisci il percorso manualmente."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbind via USB. Als het niet wordt vermeld, voer dan 'ls /dev/cu.*' in Terminal uit en voer de pad handmatig in."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecte via USB. Se não estiver listado, execute 'ls /dev/cu.*' no Terminal e insira o caminho manualmente."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Připojit přes USB. Pokud není uvedeno, spusťte 'ls /dev/cu.*' v Terminálu a zadejte cestu manuálně."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Połącz przez USB. Jeśli nie jest wyświetlony, uruchom 'ls /dev/cu.*' w Terminalu i wprowadź ścieżkę ręcznie."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Підключіться через USB. Якщо не відображено, запустіть 'ls /dev/cu.*' в Терміналі та введіть шлях вручну."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "USB経由で接続します。リストに表示されない場合は、ターミナルで「ls /dev/cu.*」を実行し、パスを手動で入力してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过 USB 连接。如果未列出，在终端中运行 'ls /dev/cu.*' 并手动输入路径。"
          }
        }
      }
