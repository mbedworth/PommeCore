      "comment": "A description of the range of the LoRa module.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Empfindlichkeit setzt CR 4/5 voraus. Reichweite ist theoretisches FSPL-Maximum mit 22 dBm TX + 2 dBi Antenne. Reale Reichweite beträgt typischerweise 30–50% des Theoretischen."
          }
        }
      },
      "shouldTranslate": false
    },
