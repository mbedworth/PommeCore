    "Long-press to copy. Share this with others to let them add you as a contact.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lang drücken zum Kopieren. Teilen Sie dies mit anderen, damit sie Sie als Kontakt hinzufügen können."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
