    "Could not connect to the device. Would you like to scan again?": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbindung zum Gerät konnte nicht hergestellt werden. Möchten Sie erneut scannen?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de se connecter à l'appareil. Souhaitez-vous scanner à nouveau ?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo conectar al dispositivo. ¿Desea escanear de nuevo?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non è stato possibile connettere al dispositivo. Vuoi riprovare a scansionare?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kon niet verbinden met het apparaat. Wil je opnieuw scannen?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível conectar ao dispositivo. Deseja digitalizar novamente?"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nemohl se připojit k zařízení. Chcete skenovat znovu?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie można połączyć się z urządzeniem. Czy chcesz zeskanować ponownie?"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не вдалося підключитися до пристрою. Хочете сканувати знову?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイスに接続できません。再度スキャンしますか？"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法连接到设备。您是否想重新扫描？"
          }
        }
      }
    },
