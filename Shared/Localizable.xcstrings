    "Better sensitivity and range, but slower data rate and longer airtime": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bessere Empfindlichkeit und Reichweite, aber langsamer Datenrate und längere Luftzeit"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Meilleure sensibilité et portée, mais taux de données plus lent et temps d'émission plus long"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mejor sensibilidad y alcance, pero velocidad de datos más lenta y tiempo de transmisión más largo"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Maggiore sensibilità e portata, ma velocità dati più lenta e tempo di trasmissione più lungo"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Betere gevoeligheid en bereik, maar langzamere datarate en langer uitzendingstijd"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Melhor sensibilidade e alcance, mas taxa de dados mais lenta e tempo de transmissão mais longo"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Lepší citlivost a dosah, ale pomalejší datový přenos a delší doba vysílání"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lepsza czułość i zasięg, ale wolniejszy transfer danych i dłuższy czas transmisji"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Краща чутливість і діапазон, але повільніша швидкість передачі даних і довший час повітряного часу"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "感度と範囲が良く、データレートが遅く、送信時間が長い"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "感度和范围更好，但数据速率较慢，空气时长较长"
          }
        }
      }
    },
    "Faster data rate and shorter airtime, but reduced range": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schnellere Datenrate und kürzere Luftzeit, aber reduzierte Reichweite"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Taux de données plus rapide et temps d'émission plus court, mais portée réduite"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Velocidad de datos más rápida y tiempo de transmisión más corto, pero alcance reducido"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Velocità dati più alta e tempo di trasmissione più breve, ma portata ridotta"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Snellere datarate en kortere uitzendingstijd, maar verminderd bereik"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Taxa de dados mais rápida e tempo de transmissão mais curto, mas alcance reduzido"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Rychlejší datový přenos a kratší doba vysílání, ale snížený dosah"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Szybszy transfer danych i krótszy czas transmisji, ale zmniejszony zasięg"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Швидша швидкість передачі даних і коротший час повітряного часу, але зменшений діапазон"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "データレートが速く、送信時間が短いが、範囲が減る"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "数据速率更快，空气时长更短，但范围减少"
          }
        }
      }
    },
    "Higher bit rate, lower sensitivity. Less affected by frequency drift": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Höhere Bitrate, niedrigere Empfindlichkeit. Weniger von Frequenzdriften betroffen"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Taux de bits plus élevé, sensibilité plus faible. Moins affecté par le dérèglement fréquentiel"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mayor tasa de bits, menor sensibilidad. Menos afectado por el desplazamiento de frecuencia"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tasso di bit più alto, sensibilità più bassa. Meno influenzato dal drift di frequenza"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hogere bitrate, lagere gevoeligheid. Minder beïnvloed door frequentieafwijking"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Taxa de bits mais alta, sensibilidade mais baixa. Menos afetado pelo desvio de frequência"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyšší bitová rychlost, nižší citlivost. Méně ovlivněno frekvenčním posuvem"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyższa szybkość bitowa, niższa czułość. Mniej podatna na drgania częstotliwościowe"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вища швидкість бітів, нижча чутливість. Менше піддається відхиленню частоти"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ビットレートが高い、感度が低い。周波数偏差の影響を受けにくい"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "比特率更高，感度较低。受频率漂移影响较小"
          }
        }
      }
    },
    "Better sensitivity and range, but more susceptible to crystal drift": {
      "localizations": {
        "de": {
