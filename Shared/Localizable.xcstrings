    "Drag across the chart to inspect elevation and clearance at any point.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Über das Diagramm ziehen, um Höhe und Freiheit an beliebigen Punkten zu prüfen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faites glisser la carte pour vérifier l'élévation et la hauteur libre en tout point."
          }
        },
        "es": {
