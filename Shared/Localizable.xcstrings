    "Sends a flood advert and SOS message to the public channel. Use only in a genuine emergency.": {
      "comment": "A description of the distress beacon.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Posílá záplavu reklam a SOS zprávu do veřejného kanálu. Použijte pouze v reálné nouzi."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sendet eine Überlastungsanzeige und einen SOS-Nachricht an den öffentlichen Kanal. Verwenden Sie dies nur bei einem echten Notfall."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía un anuncio inundación y mensaje SOS al canal público. Utilizar solo en una emergencia genuina."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoie une publicité inondation et un message SOS sur le canal public. N'utilisez que dans une véritable urgence."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Invia un annuncio allagato e messaggio SOS al canale pubblico. Utilizzare solo in caso di emergenza reale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "公のチャネルに洪水広告とSOSメッセージを送信します。本物の緊急事態のみ使用してください。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verzendt een overstromingsadvertentie en SOS-bericht naar het openbare kanaal. Gebruik alleen in noodsituaties."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wysyła reklamę powodziową i wiadomość SOS do publicznego kanału. Użyj tylko w prawdziwej sytuacji awaryjnej."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Envia um anúncio inundante e mensagem SOS para o canal público. Use apenas em uma emergência genuína."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Надсилає повільне повідомлення про рекламу та SOS до громадського каналу. Використовуйте лише у справжній надзвичайній ситуації."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "向公共频道发送大量广告和SOS消息。仅在紧急情况下使用。"
          }
        }
      }
    },
    "Sends periodic flood advertisements for the selected duration. Uses more battery and airtime than a single scan.": {
      "comment": "A description of the timed discovery feature.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Posílá periodické záplavy reklam na zadanou dobu trvání. Spotřebovává více baterie a vzdušného času než jeden sken."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sendet periodische Übertragungsankündigungen für die ausgewählte Dauer. Verbraucht mehr Akku und Sendezeit als ein einzelner Scan."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía anuncios inundación periódicos para la duración seleccionada. Usa más batería y tiempo aire que un escaneo único."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoie des publicités inondation périodiques pour la durée sélectionnée. Utilise plus de batterie et de temps air qu'un seul balayage."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Invia annunci allagati periodici per la durata selezionata. Utilizza più batteria e tempo aria rispetto a una singola scansione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択された期間中に周期的に洪水広告を送信します。単一のスキャンよりもバッテリーとエアタイムを多く消費します。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verzendt periodieke overstromingsadvertenties voor de geselecteerde duur. Gebruikt meer batterij en lucht dan een enkele scan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wysyła okresowe reklamy powodziowe na wybrany czas trwania. Zużywa więcej baterii i czasu transmisji niż pojedyncze skanowanie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Envia anúncios inundantes periódicos pela duração selecionada. Consome mais bateria e tempo de ar do que uma única varredura."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Надсилає періодичні повільні реклами на вибрану тривалість. Використовує більше батареї та повітряного часу, ніж один скан."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发送选定持续时间的周期性大量广告。比单次扫描消耗更多电池和空气时间。"
          }
        }
      }
    },
