        }
      }
    },
    "Turn on your MeshCore radio and tap the button below to scan for nearby devices.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalten Sie Ihr MeshCore-Radio ein und tippen Sie unten auf den Knopf, um nach Geräten in der Nähe zu suchen."
          }
