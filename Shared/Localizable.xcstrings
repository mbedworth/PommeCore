    "Resend failed direct messages up to 3 times before marking as failed.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fehlgeschlagene Direktnachrichten bis zu 3 Mal erneut senden, bevor sie als fehlgeschlagen markiert werden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec du réenvoi des messages directs après 3 tentatives."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reinviar mensajes fallidos se intentará hasta 3 veces antes de marcar como fallido."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rinvio fallito: i messaggi diretti verranno ritentati fino a 3 volte prima di essere contrassegnati come falliti."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hersturen van directe berichten mislukt; maximaal 3 pogingen voordat het als mislukt wordt gemarkeerd."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Reinviar mensagens diretas falhou. Tenta até 3 vezes antes de marcar como falha."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Znovu odeslání selhalo přímé zprávy až třikrát před označením jako selhané."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ponowne wysłanie wiadomości bezpośrednich nie powiodło się; maksymalnie 3 próby przed oznaczeniem jako nieudane."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Повторне відправлення прямого повідомлення не вдалося тричі перед позначенням як невдалого."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "再送信に失敗した直接メッセージは、3回まで再試行し、失敗とマークされます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重新发送失败的消息将直接重试 3 次，然后标记为失败。"
