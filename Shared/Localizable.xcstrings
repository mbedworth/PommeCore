    "Permanently erases ALL data including keys, contacts, and settings. This cannot be undone.": {
      "comment": "A description of the effect of a factory reset.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Löscht ALLE Daten dauerhaft, einschließlich Schlüssel, Kontakte und Einstellungen. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprime définitivement toutes les données, y compris les clés, les contacts et les paramètres. Cela ne peut pas être inversé."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Borra permanentemente TODOS los datos incluyendo claves, contactos y configuraciones. Esto no se puede deshacer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina permanentemente TUTTI i dati, incluse chiavi, contatti e impostazioni. Questa azione non può essere annullata."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle gegevens permanent wissen, inclusief sleutels, contacten en instellingen. Dit kan niet ongedaan gemaakt worden."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Apaga permanentemente TODOS os dados, incluindo chaves, contatos e configurações. Isso não pode ser desfeito."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vymaže trvale všechna data včetně klíčů, kontaktů a nastavení. Toto nelze vrátit zpět."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usunięcie trwałe wszystkich danych, w tym kluczy, kontaktów i ustawień. Nie można tego cofnąć."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Видаляє всі дані назавжди, включаючи ключі, контакти та налаштування. Це неможливо скасувати."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのキー、連絡先、設定を含むデータを永久に消去します。これは取り消しできません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "永久删除所有数据，包括密钥、联系人和设置。这无法撤销。"
          }
        }
      }
    },
