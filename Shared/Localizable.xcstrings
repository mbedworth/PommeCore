    "Save the firmware ZIP to your Files so the nRF DFU app can access it.": {
      "comment": "A step in the firmware update process.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Uložte firmware ZIP do svých Souborů, aby aplikace nRF DFU mohla přistupovat k němu."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Firmware-ZIP in Dateien speichern, damit die nRF-DFU-App darauf zugreifen kann."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarde el ZIP del firmware en sus Archivos para que la aplicación nRF DFU pueda acceder a él."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistrez le fichier ZIP du firmware dans vos Fichiers afin que l'application nRF DFU puisse y accéder."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Salva il file ZIP del firmware nei tuoi File in modo che l'app nRF DFU possa accedervi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "nRF DFUアプリがアクセスできるように、ファイルにファームウェアZIPを保存します。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sla het firmware ZIP-bestand op in je Bestanden zodat de nRF DFU-app er toegang toe heeft."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapisz plik ZIP z oprogramowaniem do swoich Plików, aby aplikacja nRF DFU mogła go odczytać."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Salve o arquivo ZIP do firmware nos seus Arquivos para que o aplicativo nRF DFU possa acessá-lo."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Збережіть ZIP-файл з прошивкою у свої Файли, щоб додаток nRF DFU міг до нього отримати доступ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将固件ZIP文件保存到您的文件中，以便nRF DFU应用程序可以访问它。"
          }
        }
      }
    },
