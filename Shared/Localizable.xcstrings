          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uitgaande pad is gereset. Een nieuw pad zal worden ontdekt bij de volgende communicatie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
