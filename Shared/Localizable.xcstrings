    "Standard adverts are local (0-hop, 60-240 min). Flood adverts are relayed by all repeaters (min 3 hours). Minimum intervals enforced by firmware.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Standardní reklamy jsou místní (0-hop, 60-240 min). Reklamy záplavy jsou přenášeny všemi opakovači (min 3 hodiny). Minimální intervaly vynucované firmwarem."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standard-Ankündigungen sind lokal (0-Hop, 60–240 Min.). Übertragungsankündigungen werden von allen Repeatern weitergeleitet (min. 3 Stunden). Mindestintervalle werden von der Firmware erzwungen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los anuncios estándar son locales (0-hop, 60-240 min). Los anuncios inundados son reenviados por todos los repetidores (mínimo 3 horas). Intervalos mínimos impuestos por el firmware."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les annonces standard sont locales (0-hop, 60-240 min). Les annonces Flood sont relayées par tous les répéteurs (min 3 heures). Intervalles minimaux imposés par le firmware."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le pubblicità standard sono locali (0-hop, 60-240 min). Le pubblicità flood vengono relayate da tutti i ripetitori (min 3 ore). Intervalli minimi imposti dal firmware."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "標準広告はローカル（0-ホップ、60-240分）です。フロード広告はすべてのリピーターによってリレーされます（最低3時間）。ファームウェアによって強制される最小間隔"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Standaard advertenties zijn lokaal (0-hop, 60-240 min). Flood advertenties worden door alle herhalers doorgegeven (min 3 uur). Minimale intervallen afgedwongen door firmware."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Standardowe reklamy są lokalne (0-hop, 60-240 min). Reklamy powodziowe są przekazywane przez wszystkie powtarzacze (min 3 godziny). Minimalne interwały wymuszane przez oprogramowanie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Anúncios padrão são locais (0-hop, 60-240 min). Anúncios inundados são transmitidos por todos os repetidores (mínimo 3 horas). Intervalos mínimos impostos pelo firmware."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Стандартні оголошення місцеві (0-хоп, 60-240 хв). Оголошення \"затоплення\" передаються всіма повторювачами (мін. 3 години). Мінімальні інтервали забезпечені програмним забезпеченням."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "标准广告是本地（0-跳，60-240分钟）。洪水广告由所有中继器转发（至少3小时）。固件强制最小间隔。"
          }
        }
      }
    },
    "Standard adverts are local (0-hop, 60–240 min). Flood adverts are relayed by all repeaters (min 3 hours). Minimum intervals enforced by firmware.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Standardní reklamy jsou místní (0-skok, 60–240 min). Zaplavené reklamy jsou přenášeny všemi opakovači (minimálně 3 hodiny). Minimální intervaly vynucované firmwarem."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standard-Ankündigungen sind lokal (0-Hop, 60–240 Min.). Übertragungsankündigungen werden von allen Repeatern weitergeleitet (min. 3 Stunden). Mindestintervalle werden von der Firmware erzwungen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Anuncios estándar son locales (0-salto, 60–240 min). Anuncios de inundación son reenviados por todos los repetidores (mínimo 3 horas). Intervalos mínimos impuestos por el firmware."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Annonces standard locales (0-saut, 60–240 min). Annonces de type \"inondations\" relayées par tous les répéteurs (minimum 3 heures). Intervalles minimaux imposés par le firmware."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Annunci standard sono locali (0-hop, 60–240 min). Annunci Flood sono relayati da tutti i ripetitori (min 3 ore). Intervalli minimi imposti dal firmware."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "標準広告はローカル（0ホップ、60〜240分）。洪水広告はすべてのリピーターによってリレーされます（最低3時間）。ファームウェアによって強制される最小間隔。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Standaard advertenties zijn lokaal (0-hop, 60–240 min). Overstromingsadvertenties worden door alle herhalers doorgegeven (min 3 uur). Minimale intervallen afgedwongen door firmware."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Standardowe reklamy są lokalne (0-skok, 60–240 min). Reklamy powtarzane są przez wszystkie powiady (min 3 godziny). Minimalne odstępy wymuszane przez oprogramowanie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Anúncios padrão são locais (0-salto, 60–240 min). Anúncios de inundação são retransmitidos por todos os repetidores (mínimo 3 horas). Intervalos mínimos impostos pelo firmware."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Стандартні оголошення локальні (0-стрибок, 60–240 хв). Оголошення масового поширення передаються всіма повторювачами (мінімум 3 години). Мінімальні інтервали встановлені програмним забезпеченням."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "标准广告是本地（0-跳，60–240分钟）。洪流广告由所有中继器转发（至少3小时）。固件强制最小间隔。"
          }
        }
      }
    },
