          }
        }
      }
    },
    "Change the BLE PIN from the default (123456) for security. After changing, forget this device in Bluetooth settings and re-pair with the new PIN.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ändern Sie die BLE-PIN vom Standard (123456) für mehr Sicherheit. Nach der Änderung Gerät in den Bluetooth-Einstellungen vergessen und mit der neuen PIN erneut koppeln."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Changez le PIN BLE de la configuration par défaut (123456) pour des raisons de sécurité. Après avoir modifié, oubliez cet appareil dans les paramètres Bluetooth et reconnectez-vous avec le nouveau PIN."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia el PIN de BLE desde el predeterminado (123456) por seguridad. Después de cambiarlo, olvida este dispositivo en la configuración de Bluetooth y empareja nuevamente con el nuevo PIN."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia il PIN BLE dalla impostazione predefinita (123456) per motivi di sicurezza. Dopo aver modificato, dimentica questo dispositivo nelle impostazioni Bluetooth e ricollega con il nuovo PIN."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verander de BLE PIN van de standaard (123456) voor beveiliging. Na het wijzigen, vergeten deze apparaat in Bluetooth-instellingen en koppel opnieuw met de nieuwe PIN."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Altere a senha BLE do padrão (123456) por segurança. Após a mudança, esqueça este dispositivo nas configurações Bluetooth e re-parem com o novo PIN."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Změňte PIN BLE z výchozí hodnoty (123456) z bezpečnostních důvodů. Po změně zapomeňte na toto zařízení v nastavení Bluetooth a znovu se spárujte s novým PINem."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zmień PIN BLE z domyślnego (123456) ze względów bezpieczeństwa. Po zmianie zapomnij o tym urządzeniu w ustawieniach Bluetooth i ponownie sparuj z nowym PIN-em."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Змініть PIN BLE з дефолтного (123456) для безпеки. Після зміни забувайте цей пристрій у налаштуваннях Bluetooth і знову парюйте з новим PIN."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "BLE PINをセキュリティのためにデフォルトの (123456) から変更してください。変更後は、Bluetooth設定でこのデバイスを忘れ、新しいPINで再ペアリングしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "更改蓝牙 PIN 密码以提高安全性。更改后，在蓝牙设置中忘记此设备，并使用新 PIN 重新配对。"
          }
        }
      }
    },
