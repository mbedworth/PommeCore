    "Request telemetry from the device to start collecting history.": {
      "comment": "A description of the need to request telemetry from a device to show a telemetry history chart.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Žádost o telemetrii z zařízení pro začátek shromažďování historie."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Telemetrie vom Gerät anfordern, um den Verlauf zu starten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicitar telemetría desde el dispositivo para comenzar a recopilar historial."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Demander la télémétrie depuis l'appareil pour commencer à collecter l'historique."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Richiesta telemetria dal dispositivo per iniziare a raccogliere la cronologia."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイスから履歴を収集を開始するためにテレメトリを要求します。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Telemetrie aanvragen vanaf het apparaat om geschiedenis te beginnen verzamelen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Poproś o telemetrię z urządzenia, aby rozpocząć zbieranie historii."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicitar telemetria do dispositivo para iniciar a coleta de histórico."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Запит телеметрії від пристрою для початку збору історії."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从设备请求传感器数据以开始收集历史记录。"
          }
        }
      }
    },
