    "Location access denied. Enable in Settings → Privacy → Location Services.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standortzugriff verweigert. In Einstellungen → Datenschutz → Ortungsdienste aktivieren."
