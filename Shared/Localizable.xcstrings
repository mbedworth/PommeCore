            "value": "Zero-Hop (solo nelle vicinanze)"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Null-hop (alleen in de buurt)"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Zero-Hop (apenas próximo)"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nulový skok (pouze sousední)"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zero-Hop (tylko pobliskie)"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Безперешкодний доступ (тільки поруч)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ゼロホップ（近距離のみ）"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无跳数（仅附近）"
          }
        }
      }
    },
    "Zero-hop reaches nearby nodes only. Flood is relayed by repeaters across the entire mesh network.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zero-Hop erreicht nur nahe Knoten. Übertragung wird von Repeatern im gesamten Mesh-Netzwerk weitergeleitet."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le zéro-saut n'atteint que les nœuds à proximité. Le flood est relayé par des répéteurs à travers tout le réseau maillé."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El cero-salto solo alcanza nodos cercanos. La inundación es relayada por repetidores a través de toda la red mesh."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo zero-hop raggiunge solo i nodi nelle vicinanze. Il flood viene relayato da ripetitori attraverso l'intera rete mesh."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Null-hop bereikt alleen knooppunten in de buurt. Overstroming wordt gerelayeerd door herhalers over het hele mesh-netwerk."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Zero-hop atinge apenas nós próximos. O inundação é relayada por repetidores em toda a rede mesh."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nulový skok dosahuje pouze sousedních uzlů. Povodně jsou přenášeny opakovači napříč celým mřížkovým sítí."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zero-hop dociera tylko do pobliskich węzłów. Powielanie przez powiady jest przekazywane przez całą sieć meszową."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Безперешкодний доступ досягає лише сусідніх вузлів. Повен реплікація передається повторювачами через всю мережу Mesh."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ゼロホップは近隣ノードのみに到達します。フロードはリピーターを通じてメッシュネットワーク全体にリレーされます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无跳数仅可达附近节点。整个网格网络的洪流由中继器转发。"
          }
        }
      }
    },
