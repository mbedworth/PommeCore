    "Sets the default region scope for flood packets originating from this device. Leave empty to clear.": {
      "comment": "A description of the flood scope field.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nastaví výchozí rozsah oblasti pro záplňové balíčky pocházející z tohoto zařízení. Nechte prázdné k vyčištění."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Legt den Standard-Regionsbereich für Übertragungspakete dieses Geräts fest. Zum Löschen leer lassen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Establece el alcance predeterminado de la región para paquetes inundados originados desde este dispositivo. Deja vacío para borrar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Définit la portée régionale par défaut pour les paquets inondés provenant de cet appareil. Laissez vide pour effacer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Imposta lo scope di regione predefinito per i pacchetti allagamento originati da questo dispositivo. Lascia vuoto per cancellare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスから発信される洪水パケットのデフォルト地域範囲を設定します。空白にしてクリアします。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stelt het standaardregiobereik in voor overstromingspakketten die afkomstig zijn van dit apparaat. Laat leeg om te wissen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ustawia zakres domyślny dla pakietów powodziowych pochodzących z tego urządzenia. Pozostaw puste, aby wyczyścić."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Define o escopo da região padrão para pacotes de inundação originados deste dispositivo. Deixe em branco para limpar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Встановлює область за замовчуванням для пакетів повені, що походять з цього пристрою. Залиште порожнім, щоб очистити."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设定来自该设备的洪流包的默认区域范围。留空以清除。"
          }
        }
      }
    },
