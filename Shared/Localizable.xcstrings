            "value": "打开您的MeshCore收音机，然后点击“连接”开始。"
          }
        }
      }
    },
    "Turn on your MeshCore radio and tap the button below to scan for nearby devices.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapněte svůj MeshCore rádio a klepněte na tlačítko níže pro skenování blízkých zařízení."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalten Sie Ihr MeshCore-Radio ein und tippen Sie unten auf den Knopf, um nach Geräten in der Nähe zu suchen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Enciende tu radio MeshCore y toca el botón de abajo para escanear dispositivos cercanos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Allumez votre radio MeshCore et appuyez sur le bouton ci-dessous pour scanner les appareils à proximité."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
