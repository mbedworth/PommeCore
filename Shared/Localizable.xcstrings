    "Developer and diagnostic tools. Most users won’t need these.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vývojářské a diagnostické nástroje. Většina uživatelů tyto nepotřebuje."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entwickler- und Diagnosewerkzeuge. Die meisten Benutzer benötigen diese nicht."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Herramientas de desarrollo y diagnóstico. La mayoría de los usuarios no necesitarán estas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Outils de développement et de diagnostic. La plupart des utilisateurs n'auront pas besoin de ces outils."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Strumenti di sviluppo e diagnostica. La maggior parte degli utenti non ha bisogno di questi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デベロッパーと診断ツール。ほとんどのユーザーはこれらの必要ありません。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ontwikkelaarshulpmiddelen en diagnostische tools. De meeste gebruikers hebben deze niet nodig."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Narzędzia deweloperskie i diagnostyczne. Większość użytkowników nie będzie ich potrzebować."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ferramentas de desenvolvedor e diagnóstico. A maioria dos usuários não precisará dessas."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Інструменти розробника та діагностики. Більшість користувачів не потребуватимуть цих інструментів."
          }
        },
        "zh-Hans": {
