        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lang ingedrukt om te kopiëren. Deel dit met anderen zodat zij je als contact kunnen toevoegen."
          }
        },
        "pt": {
          "stringUnit": {
