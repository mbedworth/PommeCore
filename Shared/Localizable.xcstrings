    "💚 I Want to Help! tippers can add their name to the Supporters Wall.": {
      "comment": "A description of the supporters wall",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "💚 Chci pomoci! Darovatelé mohou přidat své jméno na Zeď podporovatelů."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "💚 Ich möchte helfen!-Trinkgeldgeber können ihren Namen der Unterstützerwand hinzufügen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "💚 ¡Quiero ayudar! Los donantes pueden agregar su nombre al Muro de Apoyadores."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "💚 Je veux aider ! Les donateurs peuvent ajouter leur nom au Mur des Soutenants."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "💚 Voglio aiutare! I donatori possono aggiungere il loro nome alla parete dei sostenitori."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "💚 助けたい方は、サポートウォールに名前を追加できます。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "💚 Ik wil helpen! Donateurs kunnen hun naam toevoegen aan de Supportersmuur. (Donateurs kunnen hun naam toevoegen aan de muur van ondersteuners.)"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "💚 Chcę pomóc! Osoby wspierające mogą dodać swoje imię na Ścianę Wspierających."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "💚 Quero Ajudar! Os doadores podem adicionar seu nome à Parede de Apoiadores."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "💚 Я хочу допомогти! Допоможники можуть додати своє ім'я на стіну підтримників."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "💚 我想帮助！捐款人可以在支持者墙上添加他们的名字。"
          }
        }
      }
    },
    "$9.99 supporters also receive Watch Companion automatically.": {
