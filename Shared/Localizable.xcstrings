    "Multiplier for airtime budget. Higher values allow more frequent transmissions. 0 = no limit.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Multiplikator für Sendezeitbudget. Höhere Werte ermöglichen häufigere Übertragungen. 0 = kein Limit."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Multiplicateur pour le budget de temps aérien. Des valeurs plus élevées permettent des transmissions plus fréquentes. 0 = aucune limite."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Multiplicador para presupuesto de tiempo en el aire. Valores más altos permiten transmisiones más frecuentes. 0 = sin límite."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Moltiplicatore per budget tempo di trasmissione. Valori più alti consentono trasmissioni più frequenti. 0 = nessun limite."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vermenigvuldiger voor luchtzeitbudget. Hogere waarden maken frequentere zendingen mogelijk. 0 = geen limiet."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Multiplicador para orçamento de tempo no ar. Valores mais altos permitem transmissões mais frequentes. 0 = sem limite."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Multiplikátor rozpočtu času v éteru. Vyšší hodnoty umožňují častější přenosy. 0 = žádný limit."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Mnożnik budżetu czasu transmisji. Wyższe wartości pozwalają na częstsze transmisje. 0 = brak ograniczeń."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Множник бюджету часу в повітрі. Вища цінність дозволяє частіші передачі. 0 = без обмежень."
          }
        },
        "ja": {
