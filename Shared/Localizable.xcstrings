    "Send direct messages, join channels, and connect with others across the mesh network without internet or cell service.": {
      "comment": "A description of how to use the mesh network.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Odesílejte přímé zprávy, připojujte se k kanálům a spojujte se s ostatními přes mřížkovou síť bez internetu nebo mobilní služby."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Direktnachrichten senden, Kanäle beitreten und mit anderen im Mesh-Netzwerk kommunizieren – ohne Internet oder Mobilfunk."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Enviar mensajes directos, unirse a canales y conectarse con otros a través de la red de malla sin servicio de internet o celular."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoyer des messages directs, rejoindre des canaux et se connecter avec d'autres utilisateurs sur le réseau maillé sans connexion Internet ni service cellulaire."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Invia messaggi diretti, unisciti ai canali e connettiti con altri attraverso la rete mesh senza servizio internet o cellulare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インターネットや携帯電話サービスなしで、直接メッセージを送信し、チャネルに参加し、メッシュネットワーク上で他のユーザーに接続します。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verzend directe berichten, sluit je aan op kanalen en verbind met anderen over het mesh-netwerk zonder internet of mobiele dienst."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wysyłaj bezpośrednie wiadomości, dołączaj do kanałów i łącz się z innymi w sieci mesh bez dostępu do internetu lub usług komórkowych."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Enviar mensagens diretas, ingressar em canais e conectar-se com outros através da rede de malha sem serviço de internet ou celular."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Надсилайте прямі повідомлення, приєднуйтеся до каналів і зв'язуйтеся з іншими через мережу Mesh без доступу до інтернету або мобільного зв'язку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发送直接消息、加入频道并与网格网络中的其他人连接，无需互联网或手机服务。"
          }
        }
      }
    },
