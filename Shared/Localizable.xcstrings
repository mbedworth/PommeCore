        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uw radio is via USB verbonden. Tik op de knop hieronder om het commando te verzenden. - Uw radio is via USB aangesloten. Druk op de knop hieronder om het commando te sturen."
          }
