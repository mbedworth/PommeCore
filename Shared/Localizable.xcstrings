    "Channel secret not available locally. Recipients will need the secret separately to join.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kanalgeheimnis ist lokal nicht verfügbar. Empfänger benötigen das Geheimnis separat zum Beitreten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le secret de la chaîne n'est pas disponible localement. Les destinataires devront obtenir le secret séparément pour rejoindre."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Secreto del canal no disponible localmente. Los destinatarios necesitarán el secreto por separado para unirse."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Segreto del Canale non disponibile localmente. I destinatari avranno bisogno del segreto separatamente per unirsi."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kanaalgeheim niet beschikbaar lokaal. Ontvangers hebben het geheim apart nodig om zich aan te sluiten."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Segredo do canal não disponível localmente. Os destinatários precisarão do segredo separadamente para se juntar."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tajný klíč kanálu není k dispozici lokálně. Příjemci budou potřebovat klíč samostatně, aby se připojili."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sekret kanałowy nie jest dostępny lokalnie. Odbiorcy będą potrzebować sekretu osobno, aby dołączyć."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Секрет каналу недоступний локально. Отримувачі потребуватимуть секрету окремо, щоб приєднатися."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "チャネルの秘密はローカルでは利用できません。受信者はグループに参加するために秘密を別途入手する必要があります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
