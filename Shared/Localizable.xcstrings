    "PommeCore": {
      "shouldTranslate": false
    },
    "PommeCore is free with all features unlocked. If you find it useful, consider leaving a tip to support continued development.": {
      "comment": "A",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore ist kostenlos und alle Funktionen sind verfügbar. Wenn Sie es nützlich finden, hinterlassen Sie ein Trinkgeld zur Unterstützung der weiteren Entwicklung."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore est gratuit avec toutes les fonctionnalités déverrouillées. Si vous le trouvez utile, envisagez de laisser un pourboire pour soutenir le développement continu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore es gratuito con todas las funciones desbloqueadas. Si lo encuentras útil, considera dejar una propina para apoyar el desarrollo continuo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore è gratuito con tutte le funzionalità sbloccate. Se lo trovi utile, considera di lasciare una donazione per sostenere lo sviluppo continuo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore is gratis met alle functies ontgrendeld. Overweeg als je het nuttig vindt een tip te geven om de voortdurende ontwikkeling te ondersteunen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore é gratuito com todas as funcionalidades desbloqueadas. Se achar útil, considere deixar uma dica para apoiar o desenvolvimento contínuo."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore je zdarma s odemknutými všemi funkcemi. Pokud jej najdete užitečný, zvažte ponechání tipu na podporu dalšího vývoje."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore jest darmowy z odblokowanymi wszystkimi funkcjami. Jeśli znajdziesz to przydatne, rozważ pozostawienie napiwku na dalszy rozwój."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore безкоштовний з усіма розблокованими функціями. Якщо ви знайдете його корисним, розгляньте можливість залишити чайові для підтримки подальшого розвитку."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCoreはすべての機能が解除された無料アプリです。役に立った場合は、継続的な開発をサポートするためにチップを残してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore 免费提供，所有功能已解锁。如果您觉得它有用，请考虑留一个小费来支持持续开发。"
          }
        }
      }
    },
    "PommeCore is free with all features. Tips help fund development. 💚 tippers join the Supporters Wall!": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore ist kostenlos mit allen Funktionen. Trinkgelder finanzieren die Entwicklung. 💚 Trinkgeldgeber kommen auf die Unterstützerwand!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore est gratuit avec toutes les fonctionnalités. Les pourboires aident à financer le développement. 💚 Rejoignez le mur des soutiens !"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore es gratuito con todas las funciones. Las propinas ayudan a financiar el desarrollo. 💚 ¡Únete a la pared de patrocinadores!"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore è gratuito con tutte le funzionalità. I suggerimenti aiutano a finanziare lo sviluppo. 💚 I tipper si uniscono al Muro dei Sostenitori!"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore is gratis met alle functies. Tips helpen de ontwikkeling te financieren. 💚 Steunenden staan op de Supporters Wall!"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O PommeCore é gratuito com todas as funcionalidades. Dicas ajudam a financiar o desenvolvimento. 💚 Os doadores se juntam à Parede de Apoiadores!"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore je zdarma s veškerými funkcemi. Tipy pomáhají financovat vývoj. 💚 Připojte se k Zeď podporovatelů!"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore jest darmowy z pełną funkcjonalnością. Wskazówki pomagają w finansowaniu rozwoju. 💚 Dołączający do ściany wspierających!"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "ПоммеКор є безкоштовним з усіма функціями. Допоможіть фінансувати розвиток, залишаючи чайові! Приєднуйтесь до стіни підтримувачів!"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ポムコアはすべての機能が無料です。チップを支援して開発を資金提供しましょう！ 💚 寄付者たちはサポートウォールに参加します！"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PommeCore 免费提供所有功能。建议帮助资助开发。💚 捐赠者加入支持者墙！"
          }
        }
      }
    },
