    "Creates a channel with a random 128-bit encryption key. Share the key with others to let them join.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vytváří kanál s náhodným 128bitovým klíčem šifrování. Sdílejte klíč s ostatními, aby se mohli připojit."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstellt einen Kanal mit einem zufälligen 128-Bit-Verschlüsselungsschlüssel. Teilen Sie den Schlüssel mit anderen, damit diese beitreten können."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea un canal con una clave de cifrado aleatoria de 128 bits. Comparte la clave con otros para que puedan unirse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Crée un canal avec une clé de chiffrement aléatoire de 128 bits. Partagez la clé avec d'autres pour qu'ils puissent se joindre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea un canale con una chiave di crittografia casuale da 128 bit. Condividi la chiave con altri per consentire loro di unirsi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ランダムな128ビット暗号化キーでチャネルを作成します。キーを共有して他の人が参加できるようにします。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Maakt een kanaal met een willekeurige 128-bits versleutelingssleutel. Deel de sleutel met anderen om hen toe te laten zich aan te sluiten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tworzy kanał z losowym kluczem szyfrowania 128-bitowym. Udostępnij klucz innym, aby mogli dołączyć."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Cria um canal com uma chave de criptografia aleatória de 128 bits. Compartilhe a chave com outros para que eles possam se juntar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Створює канал з випадковим 128-бітним ключем шифрування. Поділіться ключем з іншими, щоб вони могли приєднатися."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "创建一个使用随机128位加密密钥的频道。与他人分享密钥让他们加入。"
          }
        }
      }
    },
