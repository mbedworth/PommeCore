    "Telemetry is typically only available from sensor nodes. Waiting...": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Telemetrie je obvykle k dispozici pouze z uzlů senzorů. Čekáme..."
