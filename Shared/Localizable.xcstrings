            "state": "translated",
            "value": "To zmieni Twoje radio na %@, BW %@ kHz, SF%@, CR 4/%@."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це змінить ваше радіо на %@, BW %@ kHz, SF%@, CR 4/%@."
