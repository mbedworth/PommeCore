    "Flood scope can only be cleared via USB CLI on the repeater directly.": {
      "comment": "A warning message that flood scope can only be cleared via USB CLI on the repeater directly.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Flutbereich kann nur über die USB-CLI direkt am Wiederholer gelöscht werden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le champ d'inondation ne peut être effacé que via l'interface CLI USB sur le répéteur directement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El alcance de inundación solo se puede borrar a través del CLI USB en el repetidor directamente."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo scope di flood può essere cancellato solo tramite USB CLI sul ripetitore direttamente."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De overstromingsbereik kan alleen worden leeggemaakt via USB CLI op de herhaler rechtstreeks."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O escopo de flood só pode ser limpo via USB CLI no repetidor diretamente."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zakreslení záplavy lze vyčistit pouze přes USB CLI přímo na opakovači."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zakres zalewu można wyczyścić tylko za pomocą interfejsu USB CLI na powielaczu bezpośrednio."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Область повені можна очистити лише через USB CLI на повторювачі безпосередньо."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フロードスコープは直接リピーターにUSB CLIを使用してのみクリアできます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
