    },
    "Contacts listed here can request battery, temperature, and sensor data from your device. Toggle off to stop sharing telemetry with a specific contact.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontakty uvedené zde mohou požádat o data baterie, teploty a senzorů z vašeho zařízení. Zapnutí vypnutí zastaví sdílení telemetrie s konkrétním kontaktem."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontakte, die hier aufgelistet sind, können Akku-, Temperatur- und Sensordaten von Ihrem Gerät anfordern. Deaktivieren Sie den Schalter, um die Telemetrie mit einem bestimmten Kontakt zu stoppen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los contactos listados aquí pueden solicitar datos de batería, temperatura y sensor de su dispositivo. Desactivar para dejar de compartir telemetría con un contacto específico."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les contacts listés ici peuvent demander des données batterie, température et capteur de votre appareil. Décochez pour arrêter le partage de télémétrie avec un contact spécifique."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I contatti elencati qui possono richiedere dati sulla batteria, temperatura e sensore dal tuo dispositivo. Disattiva per interrompere la condivisione dei dati di telemetria con un contatto specifico."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ここにリストされている連絡先は、デバイスからバッテリー、温度、センサーデータをリクエストできます。特定の連絡先にテレメトリーを共有するのを停止するには、オン/オフを切り替えてください。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Contacten die hier vermeld staan, kunnen batterij-, temperatuur- en sensordata aanvragen van uw apparaat. Schakel uit om telemetrie met een specifiek contact te stoppen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontakty wymienione tutaj mogą prosić o dane baterii, temperatury i czujnika z Twojego urządzenia. Wyłącz, aby zaprzestać udostępniania danych telemetrycznych konkretnemu kontaktowi."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Os contatos listados aqui podem solicitar dados de bateria, temperatura e sensor do seu dispositivo. Desligue para parar de compartilhar telemetria com um contato específico."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Контакти, перелічені тут, можуть запитувати дані батареї, температури та датчиків від вашого пристрою. Вимкніть, щоб припинити обмін телеметрією з конкретним контактом."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "列出在此的联系人可以请求设备的电池、温度和传感器数据。关闭开关以停止向特定联系人共享遥测数据。"
          }
        }
      }
    },
    "Contacts listed here will receive your GPS coordinates when they request telemetry. Toggle off to stop sharing your location with a specific contact.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontakty uvedené zde obdrží vaše GPS souřadnice, když požádají o telemetrii. Zapněte vypnutí pro zastavení sdílení vaší polohy s konkrétním kontaktem."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontakte, die hier aufgelistet sind, erhalten Ihre GPS-Koordinaten, wenn sie Telemetrie anfordern. Deaktivieren Sie den Schalter, um Ihren Standort nicht mehr mit einem bestimmten Kontakt zu teilen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los contactos listados aquí recibirán sus coordenadas GPS cuando soliciten telemetría. Desactivar para dejar de compartir su ubicación con un contacto específico."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les contacts listés ici recevront vos coordonnées GPS lorsqu'ils demandent la télémétrie. Désactivez pour arrêter de partager votre position avec un contact spécifique."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I contatti elencati qui riceveranno le tue coordinate GPS quando richiedono la telemetria. Disattiva per interrompere la condivisione della tua posizione con un contatto specifico."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ここに表示されている連絡先は、テレメトリーを要求するとGPS座標を受け取ります。特定の連絡先に場所情報を共有するのを停止するには、オフにします。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Contacten hier vermeld zullen je GPS-coördinaten ontvangen wanneer ze telemetrie aanvragen. Schakel uit om je locatie niet meer te delen met een specifieke contactpersoon."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontakty wymienione tutaj otrzymają Twoją lokalizację GPS, gdy poproszą o telemetrię. Wyłącz, aby zaprzestać udostępniania lokalizacji konkretnemu kontaktowi."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Contatos listados aqui receberão suas coordenadas GPS quando solicitarem telemetria. Desligue para parar de compartilhar sua localização com um contato específico."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Контакти, перелічені тут, отримають ваші координати GPS, коли вони запитають телеметрію. Вимкніть, щоб припинити обмін вашим розташуванням з конкретним контактом."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这里列出的联系人将接收您的 GPS 坐标，当他们请求传感数据时。关闭以停止与特定联系人共享位置。"
          }
        }
      }
    },
