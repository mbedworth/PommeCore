    "Turn on your MeshCore radio and tap Connect to begin.": {
      "comment": "A description of the onboarding flow.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapněte svůj MeshCore rádio a klepněte na Připojit pro zahájení."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalten Sie Ihr MeshCore-Radio ein und tippen Sie auf Verbinden, um zu beginnen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Enciende tu radio MeshCore y toca Conectar para comenzar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Allumez votre radio MeshCore et appuyez sur Connecter pour commencer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accendi la tua radio MeshCore e tocca Connetti per iniziare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メッシュコアのラジオをオンにし、接続をタップして開始します。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakel uw MeshCore radio in en tik op Verbind om te beginnen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Włącz radio MeshCore i naciśnij \"Połącz\", aby rozpocząć."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ligue o seu rádio MeshCore e toque em Conectar para começar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Увімкніть свій MeshCore радіо і натисніть \"Підключити\", щоб почати."
          }
        },
        "zh-Hans": {
          "stringUnit": {
