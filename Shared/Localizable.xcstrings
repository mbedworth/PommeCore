      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nachrichten in diesem Kanal werden von Ihrem Gerät gelöscht."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Messages in this channel will be deleted from your device. - Les messages sur cette chaîne seront supprimés de votre appareil."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los mensajes en este canal serán eliminados de tu dispositivo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Messages in this channel will be deleted from your device. [I messaggi in questo canale saranno eliminati dal tuo dispositivo.]"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Berichten in dit kanaal zullen van uw apparaat worden verwijderd."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As mensagens neste canal serão excluídas do seu dispositivo."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zprávy v tomto kanálu budou smazány z vašeho zařízení."
          }
        },
        "pl": {
