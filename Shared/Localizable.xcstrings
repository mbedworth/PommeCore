    "This will erase all data and cannot be undone.\n\nType RESET to confirm.": {
      "comment": "A warning message displayed in the alert for the user to confirm that they want to reset their Mesh device.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "To smaže všechna data a nelze to vrátit zpět."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Daten werden gelöscht und dies kann nicht rückgängig gemacht werden.\n\nRESET eingeben zur Bestätigung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto borrará todos los datos y no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela effacera toutes les données et ne peut pas être annulé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa operazione cancellerà tutti i dati e non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのノードが同じ設定を使用する必要があります。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit zal alle gegevens wissen en kan niet ongedaan gemaakt worden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To wyczyści wszystkie dane i nie można tego cofnąć."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso apagará todos os dados e não pode ser desfeito."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це видалить всі дані і не може бути скасовано."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将清除所有数据且无法恢复。"
          }
        }
      }
    },
    "This will permanently delete all synced messages for this radio from iCloud and all your devices. This cannot be undone.": {
      "comment": "Confirmation dialog message for deleting radio data.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Potvrďte zadáním RESET."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle synchronisierten Nachrichten für dieses Radio werden dauerhaft aus iCloud und allen Ihren Geräten gelöscht. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará permanentemente todos los mensajes sincronizados para esta radio desde iCloud y todos tus dispositivos. No se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Type RESET pour confirmer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa azione eliminerà permanentemente tutti i messaggi sincronizzati per questa radio da iCloud e da tutti i tuoi dispositivi. Non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この操作はデータをすべて消去し、元に戻すことはできません。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit zal alle gesynchroniseerde berichten voor deze radio permanent uit iCloud en alle apparaten verwijderen. Dit kan niet ongedaan gemaakt worden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To całkowicie usunie wszystkie zsynchronizowane wiadomości dla tego radia z iCloud i wszystkich Twoich urządzeń. Nie można tego cofnąć."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso excluirá permanentemente todas as mensagens sincronizadas para este rádio do iCloud e de todos os seus dispositivos. Isso não pode ser desfeito."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це назавжди видалить усі синхронізовані повідомлення для цього радіодестинації з iCloud та всіх ваших пристроїв. Це не може бути скасовано."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "输入 RESET 以确认。"
          }
        }
      }
    },
    "This will remove the selected contacts from the device. This cannot be undone.": {
      "comment": "A message for a confirmation dialog that deletes multiple contacts.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "To trvale odstraní všechny synchronizované zprávy pro toto rádio z iCloudu a všech vašich zařízení. Toto nelze vrátit zpět."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
