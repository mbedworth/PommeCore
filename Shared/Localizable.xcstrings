    },
    "The device name has been updated. A reboot is required for the change to take effect.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Gerätename wurde aktualisiert. Ein Neustart ist erforderlich, damit die Änderung wirksam wird."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le nom de l'appareil a été mis à jour. Un redémarrage est requis pour que le changement prenne effet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El nombre del dispositivo ha sido actualizado. Se requiere un reinicio para que los cambios surtan efecto."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il nome del dispositivo è stato aggiornato. È necessario un riavvio per applicare la modifica."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De apparaatnaam is bijgewerkt. Een herstart is vereist om de wijziging door te voeren."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O nome do dispositivo foi atualizado. Reinicie o dispositivo para que as alterações entrem em vigor."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Název zařízení byl aktualizován. Pro provedení změny je vyžadováno restartování zařízení."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nazwa urządzenia została zaktualizowana. Wymagana jest ponowna konfiguracja, aby zmiany weszły w życie."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Назва пристрою оновлена. Для застосування змін потрібне перезавантаження."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイスの名前が更新されました。変更を適用するには再起動が必要です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设备名称已更新。需重启以使更改生效。"
          }
        }
      }
    },
    "The device rebooted successfully. Reconnect your WiFi to your normal network if needed — the app will reconnect automatically.": {
      "comment": "A description of the firmware update process.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Gerät wurde erfolgreich neu gestartet. Verbinden Sie Ihr WiFi bei Bedarf wieder mit Ihrem normalen Netzwerk – die App verbindet sich automatisch wieder."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'appareil s'est redémarré avec succès. Reconnectez votre WiFi à votre réseau normal si nécessaire — l'application se reconnectera automatiquement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El dispositivo se reinició correctamente. Conéctese nuevamente a su red WiFi normal si es necesario; la aplicación se reconectará automáticamente."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il dispositivo si è riavviato correttamente. Ricollegare il WiFi alla rete normale se necessario — l'app si riconnetterà automaticamente."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het apparaat heeft succesvol herstart. Verbind uw WiFi met uw normale netwerk indien nodig - de app zal automatisch opnieuw verbinden."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O dispositivo reiniciou com sucesso. Reconecte sua WiFi à rede normal, se necessário — o aplicativo se reconectará automaticamente."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zařízení bylo úspěšně restartováno. Pokud je to nutné, znovu se připojte k Wi-Fi vaší normální sítě — aplikace se automaticky znovu připojí."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Urządzenie zostało pomyślnie zresetowane. Jeśli to konieczne, ponownie połącz swoją sieć WiFi z normalną siecią — aplikacja automatycznie się połączy."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Пристрій успішно перезавантажено. Якщо потрібно, підключіть свій WiFi до звичайної мережі — додаток автоматично підключиться знову."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイスは正常に再起動しました。必要に応じて通常のネットワークにWiFiを再接続してください — アプリが自動的に再接続します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设备重启成功。如需连接正常网络，请重新连接 WiFi — 应用程序将自动重新连接。"
          }
        }
      }
    },
    "The device will create a 'MeshCore-OTA' WiFi hotspot. Connect to it and use 'Download & Update Firmware' to upload the binary.": {
      "comment": "A message displayed in an alert when starting OTA mode.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Gerät erstellt einen „MeshCore-OTA“ WiFi-Hotspot. Verbinden Sie sich damit und verwenden Sie „Firmware herunterladen und aktualisieren“, um die Binärdatei hochzuladen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'appareil créera un point d'accès WiFi 'MeshCore-OTA'. Connectez-vous-y et utilisez 'Télécharger et mettre à jour le firmware' pour télécharger le binaire."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El dispositivo creará un punto de acceso 'MeshCore-OTA' WiFi. Conéctese a él y utilice 'Descargar y actualizar firmware' para cargar el binario."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il dispositivo creerà un hotspot WiFi 'MeshCore-OTA'. Connetti e usa 'Scarica e Aggiorna Firmware' per caricare il binario."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het apparaat zal een 'MeshCore-OTA' WiFi hotspot creëren. Verbind eraan en gebruik 'Firmware downloaden & bijwerken' om het binaire bestand te uploaden."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O dispositivo criará um ponto de acesso 'MeshCore-OTA' WiFi. Conecte-se a ele e use 'Baixar & Atualizar Firmware' para enviar o binário."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zařízení vytvoří Wi-Fi hotspot 'MeshCore-OTA'. Připojte se k němu a použijte 'Stáhnout a aktualizovat firmwar' pro nahrání binárního souboru."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Urządzenie utworzy punkt dostępowy 'MeshCore-OTA' WiFi. Połącz się z nim i użyj 'Pobierz i zaktualizuj oprogramowanie' do przesłania binarnego."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Пристрій створить Wi-Fi гарячу точку \"MeshCore-OTA\". Підключіться до неї та використовуйте \"Завантажити та оновити прошивку\", щоб завантажити бінарний файл."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイスは「MeshCore-OTA」のWiFiホットスポットを作成します。それに接続し、「ファームウェアをダウンロード＆更新」を使用してバイナリをアップロードします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设备将创建一个 'MeshCore-OTA' WiFi 热点。连接到它并使用 '下载并更新固件' 上传二进制文件。"
          }
        }
      }
    },
    "The radio will disconnect and restart. You'll need to reconnect via Bluetooth.": {
      "comment": "A warning message displayed when the user is about to reboot their Mesh device.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Radio wird getrennt und neu gestartet. Sie müssen sich erneut über Bluetooth verbinden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La radio se déconnectera et redémarrera. Vous devrez vous reconnecter via Bluetooth."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La radio se desconectará y reiniciará. Necesitará reconectarse vía Bluetooth."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La radio si scollegherà e riavvierà. Dovrai ricollegarti tramite Bluetooth."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De radio zal zich ontkoppelen en herstarten. Je moet opnieuw via Bluetooth verbinden."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O rádio desconectará e reiniciará. Você precisará se reconectar via Bluetooth."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Radio bude odpojené a restartované. Budete muset znovu připojit přes Bluetooth."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Radio zostanie odłączone i ponownie uruchomione. Będziesz musiał ponownie połączyć się za pomocą Bluetooth."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Радіо від'єднається та перезавантаиться. Вам потрібно буде знову підключитися через Bluetooth."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ラジオは切断して再起動します。Bluetooth経由で再度接続する必要があります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无线电将断开连接并重启。您需要通过蓝牙重新连接。"
          }
        }
      }
    },
    "The remote device will restart. You will need to log in again.": {
      "comment": "Confirmation alert for rebooting a remote device.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das entfernte Gerät wird neu gestartet. Sie müssen sich erneut anmelden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'appareil distant redémarrera. Vous devrez vous connecter à nouveau."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El dispositivo remoto se reiniciará. Necesitará iniciar sesión nuevamente."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il dispositivo remoto si riavvierà. Dovrai accedere di nuovo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het externe apparaat zal herstarten. Je moet opnieuw inloggen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O dispositivo remoto reiniciará. Você precisará fazer login novamente."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vzdálené zařízení bude restartované. Budete muset se přihlásit znovu."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odległe urządzenie zostanie zresetowane. Będziesz musiał zalogować się ponownie."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Віддалений пристрій перезавантажиться. Вам потрібно буде увійти знову."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リモートデバイスが再起動します。ログインし直す必要があります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "远程设备将重启。您需要再次登录。"
          }
        }
      }
    },
    "Theme": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Design"
          }
