        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Standortbestimmung konnte nicht erfolgen. Aktivieren Sie die Standortdienste für PommeCore in den Einstellungen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'emplacement ne pourrait pas être déterminé. Activez les Services de localisation pour PommeCore dans Réglages."
