    "Power on your MeshCore radio and make sure Bluetooth is enabled on your device.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalten Sie Ihr MeshCore-Radio ein und stellen Sie sicher, dass Bluetooth auf Ihrem Gerät aktiviert ist."
          }
        },
        "fr": {
