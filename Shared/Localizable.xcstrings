          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Incolla la chiave privata codificata in esadecimale da un backup precedente. Il dispositivo riavvierà dopo il ripristino."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg de hex-gecodeerde privé sleutel uit een eerdere back-up in: De apparaat zal opnieuw opstarten na het herstellen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Cole a chave privada codificada em hex de um backup anterior. O dispositivo reiniciará após a restauração."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vložte hexově zakódovaný soukromý klíč z předchozího zálohovacího souboru. Zařízení se restartuje po obnovení."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wklej zakodowany w formacie hex klucze prywatne z poprzedniego kopii zapasowej. Urządzenie zostanie ponownie uruchomione po przywróceniu."
          }
        },
        "uk": {
          "stringUnit": {
