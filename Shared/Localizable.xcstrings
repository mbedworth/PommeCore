    "Switch your radio to %@? This changes your frequency, SF, and bandwidth.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalten Sie Ihr Radio auf %@? Dies ändert Ihre Frequenz, SF und Bandbreite."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Changez de radio ? Cela modifie votre fréquence, SF et bande passante."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia tu radio a %@? Esto modifica tu frecuencia, SF y ancho de banda."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Passa la tua radio a %@? Questo cambia la frequenza, SF e larghezza di banda."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakel uw radio naar %@? Dit verandert uw frequentie, SF en bandbreedte."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mude o seu rádio para %@? Isso altera sua frequência, SF e largura de banda."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přepněte své rádio na %@? To změní vaši frekvenci, SF a šířku pásma."
