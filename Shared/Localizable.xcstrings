    "Long-press to copy. Share this with others to let them add you as a contact.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Dlouze stiskněte pro kopírování. Sdílejte toto s ostatními, aby vás mohli přidat jako kontakt."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lang drücken zum Kopieren. Teilen Sie dies mit anderen, damit sie Sie als Kontakt hinzufügen können."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén presionado para copiar. Comparte esto con otros para que te agreguen como contacto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintenez appuyé pour copier. Partagez ceci avec d'autres pour qu'ils vous ajoutent comme contact."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tenis premuto per copiare. Condividi questo con altri per permettergli di aggiungerti come contatto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "長押ししてコピー。これを他の人と共有して、あなたを連絡先として追加できるようにしてください。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lang ingedrukt om te kopiëren. Deel dit met anderen zodat zij je als contact kunnen toevoegen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Trwajnie przytrzymaj, aby skopiować. Udostępnij to innym, aby dodali Cię jako kontakt."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Segure para copiar. Compartilhe isso com outros para que eles possam adicioná-lo como contato."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Тривале натиснення для копіювання. Поділіться цим з іншими, щоб вони додали вас як контакт."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
