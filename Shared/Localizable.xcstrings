    "Send an advertisement to announce your presence on the mesh. Other nodes will appear here as they respond.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Odešlete reklamu k oznámení své přítomnosti v mřížce. Jiné uzly se zde objeví, jakmile odpoví."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ankündigung senden, um die eigene Präsenz im Mesh bekannt zu geben. Andere Knoten erscheinen hier, sobald sie antworten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Enviar un anuncio para anunciar su presencia en la malla. Otros nodos aparecerán aquí a medida que respondan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoyer une publicité pour annoncer votre présence sur le maillage. Les autres nœuds apparaîtront ici au fur et à mesure de leur réponse."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Invia un annuncio per segnalare la tua presenza sulla mesh. Altri nodi appariranno qui mentre rispondono."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メッシュ上で存在を知らせる広告を送信します。応答するノードがここに表示されます。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verzend een advertentie om je aanwezigheid in het mesh-netwerk aan te kondigen. Andere knooppunten verschijnen hier wanneer ze reageren."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyślij reklamę, aby ogłosić swoją obecność w sieci mesh. Inne węzły pojawią się tutaj, gdy odpowiedzą."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Enviar um anúncio para anunciar sua presença na malha. Outros nós aparecerão aqui à medida que respondem."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Надіслати оголошення для повідомлення про свою присутність у мережі. Інші вузли з'являться тут, коли вони відповіють."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "向网格发送广告以宣布您的存在。其他节点将在此处出现，因为它们响应。"
          }
        }
      }
    },
