    "Exports radio name, frequency, spreading factor, bandwidth, TX power, channels, and access settings.": {
      "comment": "A description of the export process.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportuje název rádia, frekvenci, faktor šíření, šířku pásma, výkon přenosu, kanály a nastavení přístupu."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Funkname, Frequenz, Ausbreitfaktor, Bandbreite, Sendeleistung, Kanäle und Zugangs-Einstellungen exportieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporta el nombre de la radio, frecuencia, factor de dispersión, ancho de banda, potencia de transmisión, canales y configuraciones de acceso."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporte le nom de radio, la fréquence, le facteur de diffusion, la bande passante, la puissance TX, les canaux et les paramètres d'accès."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esporta nome radio, frequenza, fattore di diffusione, larghezza di banda, potenza di trasmissione, canali e impostazioni di accesso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ラジオ名、周波数、スプレッディングファクター、帯域幅、送信電力、チャネル、アクセス設定をエクスポートします。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporteert radio-naam, frequentie, spreidingsfactor, bandbreedte, zendkracht, kanalen en toegangsinstellingen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Eksportuje nazwę radia, częstotliwość, czynnik rozprzestrzeniania, pasmo, moc nadajnika, kanały i ustawienia dostępu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporta o nome do rádio, frequência, fator de espalhar, largura de banda, potência de transmissão, canais e configurações de acesso."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Експортує назву радіоприймача, частоту, фактор розсіювання, смугу пропускання, потужність передачі, канали та налаштування доступу."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导出无线电名称、频率、扩散因子、带宽、发射功率、频道和访问设置。"
          }
        }
      }
    },
