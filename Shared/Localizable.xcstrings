    "Sensors require admin access. Guest login is not supported.": {
      "comment": "A warning message for sensors that explain that guest login is not supported.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Senzory vyžadují přístup správce. Přihlášení hosta není podporováno."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sensoren erfordern Administratorzugriff. Gast-Anmeldung wird nicht unterstützt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los sensores requieren acceso de administrador. El inicio de sesión de invitado no está soportado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les capteurs nécessitent un accès administrateur. Connexion en tant qu'invité non prise en charge."
