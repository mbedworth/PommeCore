    "Direct GPIO pin control. Use with caution — incorrect operations may affect sensor readings.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Direkte GPIO-Pin-Steuerung. Mit Vorsicht verwenden — falsche Operationen können die Sensorwerte beeinflussen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Contrôle direct de la broche GPIO. Utilisez avec précaution — les opérations incorrectes peuvent affecter les lectures du capteur."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Control directo de pines GPIO. Utilizar con precaución — operaciones incorrectas pueden afectar las lecturas del sensor."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Controllo pin GPIO diretto. Utilizzare con cautela - operazioni errate possono influenzare le letture del sensore."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Directe GPIO-pinbesturing. Gebruik voorzichtig — onjuiste bewerkingen kunnen de sensorgegevens beïnvloeden."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Controle de pino GPIO direto. Use com cautela — operações incorretas podem afetar leituras do sensor."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přímá kontrola GPIO pinu. Používejte s opatrností – nesprávné operace mohou ovlivnit čtení senzorů."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bezpośrednie sterowanie pinem GPIO. Używaj z ostrożnością — nieprawidłowe operacje mogą wpłynąć na odczyty czujnika."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Прямий контроль GPIO-пінів. Використовуйте обережно — неправильні операції можуть вплинути на показники сенсора."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "直接GPIOピン制御。注意して使用してください — 不正な操作はセンサーリーディングに影響を与える可能性があります。"
          }
        },
        "zh-Hans": {
