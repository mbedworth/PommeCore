        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Po nawiązaniu połączenia, kontakty i kanały zostaną automatycznie zsynchronizowane."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
