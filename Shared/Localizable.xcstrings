    "Set a local nickname for %@. This is only visible to you.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nastavte místní přezdívku pro %@. Tato je viditelná pouze vám."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokalen Spitznamen für %@ festlegen. Dieser ist nur für Sie sichtbar."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Establece un apodo local para %@. Esto solo es visible para ti."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Définissez un surnom local pour %@. Celui-ci n'est visible que par vous."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Imposta un soprannome locale per %@. Questo è visibile solo a te."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@にローカルニックネームを設定します。これはあなただけに見えます。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stel een lokale bijnaam in voor %@. Dit is alleen zichtbaar voor jou."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ustaw lokalne pseudonimy dla %@. Widoczne tylko dla Ciebie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Defina um apelido local para %@. Isso é visível apenas para você."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Встановити локальну псевдонім для %@. Це видно лише вам."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为 %@ 设置本地昵称。仅你可见。"
          }
        }
      }
    },
    "Set from Phone GPS copies your phone’s coordinates to the radio. Auto-Update periodically refreshes while the app is open.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nastavení z telefonu GPS kopíruje souřadnice vašeho telefonu do rádia. Automatické aktualizace periodicky obnovují, zatímco je aplikace otevřená."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Von Telefon-GPS setzen kopiert die Koordinaten Ihres Telefons zum Radio. Automatische Aktualisierung aktualisiert regelmäßig, während die App geöffnet ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Configurar GPS del teléfono copia las coordenadas de tu teléfono a la radio. Actualización automática actualiza periódicamente mientras la aplicación esté abierta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Définir depuis GPS du téléphone copie les coordonnées de votre téléphone sur la radio. La mise à jour automatique rafraîchit périodiquement tant que l'application est ouverte."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Imposta dalla GPS del telefono copia le coordinate del tuo telefono sulla radio. Aggiornamento automatico rinfresca periodicamente mentre l'app è aperta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "電話のGPSからラジオに携帯電話の座標をコピーします。アプリがオープンしている間、定期的に自動更新されます。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stel GPS-coördinaten van je telefoon in om ze naar de radio te kopiëren. Periodieke automatische updates vernieuwen terwijl de app openstaat."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ustawienie GPS z telefonu kopiuje współrzędne Twojego telefonu do radia. Aktualizacja automatyczna odświeża okresowo, gdy aplikacja jest otwarta."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Configurar GPS do Telefone copia as coordenadas do seu telefone para o rádio. Atualização Automática atualiza periodicamente enquanto o aplicativo está aberto."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Налаштувати GPS телефону копіює координати вашого телефону на радіоприймач. Автоматичне оновлення періодично оновлює інформацію, поки додаток відкритий."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从手机 GPS 设置将你的手机坐标复制到收发器中。自动更新在应用打开时定期刷新。"
          }
        }
      }
    },
