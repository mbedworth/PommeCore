          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie można określić lokalizacji. Włącz usługi lokalizacyjne dla PommeCore w Ustawieniach."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не вдалося визначити ваше місцезнаходження. Увімкніть послуги розташування для PommeCore в налаштуваннях."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "位置情報が取得できません。設定でPommeCoreの位置情報サービスを有効にしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法确定您的位置。在设置中启用 PommeCore 的位置服务。"
          }
        }
      }
    },
    "Your radio is connected via USB. Tap the button below to send the command.": {
      "comment": "A message displayed in the firmware update flow.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
