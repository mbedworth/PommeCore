    "Paste the hex-encoded private key from a previous backup. The device will reboot after restoring.": {
      "comment": "A message displayed in a button that restores a device's private key.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vložte hexově zakódovaný soukromý klíč z předchozího zálohovacího souboru. Zařízení se restartuje po obnovení."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hex-kodierten privaten Schlüssel aus einem früheren Backup einfügen. Das Gerät wird nach der Wiederherstellung neu gestartet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pegar la clave privada codificada en hex de una copia de seguridad anterior. El dispositivo se reiniciará después de la restauración."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Coller la clé privée codée en hexadécimal d'une sauvegarde précédente. L'appareil redémarrera après la restauration."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Incolla la chiave privata codificata in esadecimale da un backup precedente. Il dispositivo riavvierà dopo il ripristino."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "前回のバックアップからヘックスでエンコードされたプライベートキーを貼り付けます。復元後、デバイスが再起動します。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg de hex-gecodeerde privé sleutel uit een eerdere back-up in: De apparaat zal opnieuw opstarten na het herstellen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wklej zakodowany w formacie hex klucze prywatne z poprzedniego kopii zapasowej. Urządzenie zostanie ponownie uruchomione po przywróceniu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Cole a chave privada codificada em hex de um backup anterior. O dispositivo reiniciará após a restauração."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вставте закодований у шестерню приватний ключ з попереднього резервного копіювання. Пристрій перезавантажиться після відновлення."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "粘贴从之前备份中解码后的私钥。设备在恢复后将重启。"
          }
        }
      }
    },
