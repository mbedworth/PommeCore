    "Blocked contacts won't appear in your contact list and their messages will be suppressed.": {
      "comment": "A description of the effect of blocking contacts.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Blokované kontakty se neobjeví ve vašem seznamu kontaktů a jejich zprávy budou potlačeny."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gesperrte Kontakte erscheinen nicht in Ihrer Kontaktliste und ihre Nachrichten werden unterdrückt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los contactos bloqueados no aparecerán en su lista de contactos y sus mensajes serán suprimidos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les contacts bloqués ne figureront pas sur votre liste de contacts et leurs messages seront supprimés."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I contatti bloccati non appariranno nella tua lista contatti e i loro messaggi saranno soppressi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブロックされた連絡先は連絡先リストに表示されず、メッセージは抑制されます。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Blocked contacts won't appear in your contact list and their messages will be suppressed. - Geblokkeerde contacten verschijnen niet in je contactlijst en hun berichten worden onderdrukt."
          }
        },
        "pl": {
