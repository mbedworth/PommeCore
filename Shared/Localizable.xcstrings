    "Hashtag channels derive their encryption key from the channel name. Anyone who knows the name can join.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Kanály s hashtagy odvozují svůj klíč šifrování z názvu kanálu. Kdo zná název, může se připojit."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hashtag-Kanäle leiten ihren Verschlüsselungsschlüssel aus dem Kanalnamen ab. Jeder, der den Namen kennt, kann beitreten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los canales con hashtag derivan su clave de cifrado del nombre del canal. Cualquiera que sepa el nombre puede unirse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les canaux Hashtag tirent leur clé de chiffrement du nom du canal. Tout le monde qui connaît le nom peut rejoindre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I canali hashtag derivano la loro chiave di crittografia dal nome del canale. Chiunque conosca il nome può unirsi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ハッシュタグチャンネルはチャンネルの名前から暗号化キーを取得します。名前を知っている人は誰でも参加できます。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hashtag-kanalen halen hun versleutelingssleutel uit de kanaalnamen. Iedereen die de naam kent, kan zich aansluiten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kanały hashtagowe czerpią klucz szyfrowania z nazwy kanału. Każdy, kto zna nazwę, może dołączyć."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Canais com hashtag derivam sua chave de criptografia do nome do canal. Qualquer um que saiba o nome pode se juntar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Канали хештегів отримують свій ключ шифрування від назви каналу. Будь-хто, хто знає назву, може приєднатися."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "哈希频道从频道名称中获取加密密钥。知道名称的任何人都可以加入。"
          }
        }
      }
    },
