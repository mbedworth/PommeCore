    "Passwords are case-sensitive, max 15 characters.": {
      "comment": "A note about the format of room server passwords.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Passwörter unterscheiden Groß-/Kleinschreibung, max. 15 Zeichen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les mots de passe sont sensibles à la casse, maximum 15 caractères."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las contraseñas son sensibles a mayúsculas y minúsculas, un máximo de 15 caracteres."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le password sono sensibili alle maiuscole, al massimo 15 caratteri."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wachtwoorden zijn hoofdlettergevoelig, maximaal 15 tekens."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As senhas são sensíveis a maiúsculas e minúsculas, até 15 caracteres."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Hesla jsou citlivá na velká a malá písmena, maximálně 15 znaků."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hasła są wrażliwe na wielkość liter, maksymalnie 15 znaków."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Паролі чутливі до регістру, максимум 15 символів."
          }
        },
        "ja": {
          "stringUnit": {
