    },
    "Allow Read-Only lets guests read messages without a password. Disable to require authentication for all access.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur lesen erlaubt ermöglicht Gästen das Lesen von Nachrichten ohne Passwort. Deaktivieren, um für alle Zugriffe eine Authentifizierung zu erfordern."
          }
        }
      }
    },
