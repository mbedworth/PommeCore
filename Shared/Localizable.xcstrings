    "Send messages, share channels, and connect with others using LoRa radio — no internet or cell service needed.": {
      "comment": "A description of the benefits of using PommeCore.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Posílejte zprávy, sdílejte kanály a spojujte se s ostatními pomocí rádia LoRa – nepotřebujete internet ani mobilní službu."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nachrichten senden, Kanäle teilen und mit anderen per LoRa-Radio kommunizieren – kein Internet oder Mobilfunk erforderlich."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Enviar mensajes, compartir canales y conectarse con otros utilizando radio LoRa — no se necesita servicio de internet o celular."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoyer des messages, partager des canaux et se connecter avec d'autres en utilisant la radio LoRa — pas besoin de connexion Internet ou cellulaire."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Invia messaggi, condividi canali e connettiti con altri utilizzando la radio LoRa - non è necessario il servizio internet o cellulare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "LoRaラジオを使用してメッセージを送信し、チャネルを共有し、インターネットや携帯電話サービスなしで他のユーザーと接続します。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verzend berichten, deel kanalen en verbind met anderen met behulp van LoRa-radio - geen internet of mobiele dienst vereist."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wysyłaj wiadomości, dziel się kanałami i łącz się z innymi za pomocą radia LoRa - nie potrzebujesz internetu ani usług komórkowych."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Enviar mensagens, compartilhar canais e conectar-se com outros usando rádio LoRa — sem necessidade de internet ou serviço celular."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Надсилати повідомлення, ділитися каналами та зв'язуватися з іншими за допомогою радіомодуля LoRa — без потреби в інтернеті або мобільному зв'язку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 LoRa 无线电发送消息、共享频道并与他人连接 - 无需互联网或手机服务。"
          }
        }
      }
    },
    "Send raw CLI commands to the device. Type 'help' for available commands.": {
