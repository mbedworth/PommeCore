        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uw locatie kon niet worden bepaald. Schakel Locatiediensten in voor PommeCore in Instellingen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A localização não pôde ser determinada. Ative os Serviços de Localização para PommeCore nas Configurações."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
