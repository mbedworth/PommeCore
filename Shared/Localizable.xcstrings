    "Are you sure you want to remove %@? This will delete all messages with this contact.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchten Sie %@ wirklich entfernen? Dabei werden alle Nachrichten mit diesem Kontakt gelöscht."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Êtes-vous sûr de vouloir supprimer %@ ? Cela effacera tous les messages avec ce contact."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Estás seguro de querer eliminar %@? Esto borrará todos los mensajes con este contacto."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei sicuro di voler rimuovere %@? Questo eliminerà tutti i messaggi con questo contatto."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Weet je zeker dat je %@ wilt verwijderen? Dit zal alle berichten met dit contact verwijderen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você tem certeza que deseja remover %@? Isso excluirá todas as mensagens com este contato."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Jste si jisti, že chcete odstranit %@? To smaže všechny zprávy s tímto kontaktem."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czy na pewno chcesz usunąć %@? Usunie to wszystkie wiadomości z tym kontaktem."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви впевнені, що хочете видалити %@? Це видалить усі повідомлення з цим контактом."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@を削除してもよろしいですか？この連絡先を含むすべてのメッセージが削除されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你确定要移除 %@ 吗？这将删除所有与这个联系人相关的消息。"
          }
        }
      }
    },
