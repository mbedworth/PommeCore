    "Paste the hex-encoded private key from a previous backup. The device will reboot after restoring.": {
      "comment": "A message displayed in a button that restores a device's private key.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
