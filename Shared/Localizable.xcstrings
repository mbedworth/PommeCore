    "Send an advertisement to announce your presence on the mesh. Other nodes will appear here as they respond.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ankündigung senden, um die eigene Präsenz im Mesh bekannt zu geben. Andere Knoten erscheinen hier, sobald sie antworten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoyer une publicité pour annoncer votre présence sur le maillage. Les autres nœuds apparaîtront ici au fur et à mesure de leur réponse."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
