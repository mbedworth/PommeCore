    "Copy all message history from the old radio to your currently connected radio.": {
      "comment": "A description of the action of migrating radio data.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zkopírujte veškerou historii zpráv z původního rádia do vašeho aktuálně připojeného rádia."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gesamten Nachrichtenverlauf vom alten Radio auf das aktuell verbundene Radio kopieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiar todo el historial de mensajes del antiguo radio a su radio actualmente conectado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Copier l'historique complet des messages de l'ancien radio vers votre radio actuellement connecté."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Copia tutta la cronologia dei messaggi dall'antica radio alla tua radio attualmente connessa."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
