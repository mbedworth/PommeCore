    "Debug Log records connection and protocol events for troubleshooting.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Protokol ladění zaznamenává připojení a události protokolu pro řešení problémů."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Debug-Protokoll zeichnet Verbindungs- und Protokollereignisse zur Fehlerbehebung auf."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El registro de depuración registra eventos de conexión y protocolo para la resolución de problemas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le journal de débogage enregistre les événements de connexion et de protocole pour le dépannage."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il log di debug registra gli eventi di connessione e protocollo per la risoluzione dei problemi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバッグログは、接続とプロトコルイベントを記録し、トラブルシューティングに役立ちます。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Foutlog registreert verbinding en protocolgebeurtenissen voor foutopsporing."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Logi debugowania rejestrują połączenia i zdarzenia protokołów do rozwiązywania problemów."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O log de depuração registra eventos de conexão e protocolo para solução de problemas."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Лог відладки записує події підключення та протоколу для налагодження."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
