    "Factory reset erases all contacts, channels, settings, and encryption keys from the device. This cannot be undone.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Obnovení továrního nastavení smaže všechny kontakty, kanály, nastavení a šifrovací klíče z zařízení. Toto nelze vrátit zpět."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Werkseinstellung löscht alle Kontakte, Kanäle, Einstellungen und Verschlüsselungsschlüssel vom Gerät. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El reinicio de fábrica borrará todos los contactos, canales, configuraciones y claves de cifrado del dispositivo. Esto no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La réinitialisation d'usine efface tous les contacts, canaux, paramètres et clés de chiffrement du dispositif. Cela ne peut pas être annulé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il reset di fabbrica cancella tutti i contatti, i canali, le impostazioni e le chiavi di crittografia dal dispositivo. Non può essere annullato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "工場出荷時復元は、すべての連絡先、チャネル、設定、暗号化キーをデバイスから削除します。これは取り消しできません。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Fabrieksherstel verwijdert alle contacten, kanalen, instellingen en versleutelingssleutels van het apparaat. Dit kan niet ongedaan gemaakt worden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Reset fabryczny usuwa wszystkie kontakty, kanały, ustawienia i klucze szyfrowania z urządzenia. Nie można tego cofnąć."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O reinício da fábrica apaga todos os contatos, canais, configurações e chaves de criptografia do dispositivo. Isso não pode ser desfeito."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Скидання до заводських налаштувань видалить усі контакти, канали, налаштування та ключі шифрування з пристрою. Це неможливо відновити."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "工厂重置将清除设备上的所有联系人、频道、设置和加密密钥。此操作不可逆转。"
          }
        }
      }
    },
