    "Chat = people, Repeaters extend range, Room Servers host group chats, Sensors report data.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Chat = Personen, Repeater erweitern die Reichweite, Raumserver hosten Gruppenchats, Sensoren berichten Daten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chat = personnes, Répéteurs étendent la portée, Serveurs de salle hébergent des discussions de groupe, Capteurs rapportent les données."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Chat = personas, Repetidores extienden el alcance, Servidores de sala alojan chats grupales, Sensores reportan datos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chat = persone, Ripetitori estendono la portata, Server della Stanza ospitano chat di gruppo, Sensori riportano dati."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Chat = mensen, Herhalers verlengen het bereik, Ruimte-servers hosten groepsgesprekken, Sensoren rapporteren data."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Chat = pessoas, Repetidores estendem o alcance, Servidores de sala hospedam chats em grupo, Sensores relatam dados."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Chat = lidé, opakovače rozšiřují dosah, servery místností hostují skupinové chaty, senzory hlásí data."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czat = ludzie, Powtarzacze rozszerzają zasięg, Serwery pokoi hostują czaty grupowe, Czujniki zgłaszają dane."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Чат = люди, Повторювачі розширюють діапазон, Сервери кімнат приймають групові чати, Сенсори повідомляють дані."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "チャット = 人、リピーターは範囲を拡張、ルームサーバーはグループチャットをホスト、センサーはデータを報告。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "聊天 = 人，中继器扩展范围，房间服务器托管群组聊天，传感器报告数据。"
          }
        }
      }
    },
