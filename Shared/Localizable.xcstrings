    "Add \"%@\" to your channels, or replace all existing channels?": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přidejte \"%@\" do svých kanálů, nebo nahraďte všechny existující kanály?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" zu Ihren Kanälen hinzufügen oder alle bestehenden Kanäle ersetzen?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agregar \"%@\" a tus canales, o reemplazar todos los canales existentes?"
