    "Adds a random offset to your location before sharing. Only affects your personal device — repeater and room server locations are always exact.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přidává náhodný posun vaší polohy před sdílením. Týká se pouze vašeho osobního zařízení - umístění opakovače a serveru místnosti jsou vždy přesná."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügt Ihrem Standort vor dem Teilen einen zufälligen Versatz hinzu. Betrifft nur Ihr persönliches Gerät — Repeater- und Raumserver-Standorte sind immer genau."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade un desplazamiento aleatorio a tu ubicación antes de compartir. Solo afecta a tu dispositivo personal; las ubicaciones del repetidor y el servidor de sala son siempre exactas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoute un décalage aléatoire à votre localisation avant le partage. Ne concerne que votre appareil personnel — les emplacements du répéteur et du serveur de pièce sont toujours exacts."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiunge un offset casuale alla tua posizione prima di condividere. Influisce solo sul tuo dispositivo personale; le posizioni del ripetitore e del server della stanza sono sempre esatte."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "共有前に位置情報にランダムなオフセットを追加します。個人のデバイスのみに影響し、リピーターとルームサーバーの場所は常に正確です。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voegt een willekeurige offset toe aan je locatie voordat deze wordt gedeeld. Beïnvloedt alleen je persoonlijke apparaat — locaties van herhalers en kamer servers zijn altijd exact."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodaje losowy przesunięcie do Twojej lokalizacji przed udostępnieniem. Dotyczy tylko Twojego osobistego urządzenia — lokalizacje powielacza i serwera pokoju są zawsze dokładne."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adiciona um deslocamento aleatório à sua localização antes de compartilhar. Afeta apenas o seu dispositivo pessoal — as localizações do repetidor e do servidor de sala são sempre exatas."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Додає випадкове зміщення до вашого розташування перед поширенням. Впливає лише на ваше особисте пристрій — місцезнаходження повторювача та серверу кімнати завжди точні."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在分享前随机偏移您的位置。仅影响个人设备 - 重复器和房间服务器位置始终精确。"
          }
        }
      }
