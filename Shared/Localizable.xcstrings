    "Requires Apple Watch paired with this iPhone. Messages sync via WatchConnectivity when your iPhone is nearby or reachable.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfordert eine Apple Watch, die mit diesem iPhone gekoppelt ist. Nachrichten werden über WatchConnectivity synchronisiert, wenn Ihr iPhone in der Nähe ist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nécessite une Apple Watch associée à cet iPhone. Les messages sont synchronisés via WatchConnectivity lorsque votre iPhone est proche ou accessible."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Requiere Apple Watch emparejado con este iPhone. Los mensajes se sincronizan a través de WatchConnectivity cuando tu iPhone está cerca o es alcanzable."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Richiede Apple Watch abbinato a questo iPhone. I messaggi vengono sincronizzati tramite WatchConnectivity quando il tuo iPhone è nelle vicinanze o raggiungibile."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vereist Apple Watch gekoppeld aan deze iPhone. Berichten worden gesynchroniseerd via WatchConnectivity wanneer je iPhone in de buurt is of bereikbaar."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Requer Apple Watch emparelhado com este iPhone. Mensagens sincronizadas via WatchConnectivity quando o iPhone estiver próximo ou acessível."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyžaduje se Apple Watch spárované s tímto iPhonem. Zprávy se synchronizují přes WatchConnectivity, když je váš iPhone poblíž nebo dosažitelný."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wymaga Apple Watch sparowanego z tym iPhone'em. Wiadomości synchronizowane są za pośrednictwem WatchConnectivity, gdy iPhone jest w pobliżu lub dostępny."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вимагає Apple Watch, підключений до цього iPhone. Повідомлення синхронізуються через WatchConnectivity, коли ваш iPhone поруч або доступний."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このiPhoneとApple Watchのペアリングが必要です。iPhoneが近くまたは到達可能な場合は、WatchConnectivityを通じてメッセージが同期します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要与这款 iPhone 配对的 Apple Watch。当你的 iPhone 附近或可访问时，消息将通过 WatchConnectivity 同步。"
          }
        }
      }
    },
