    "Thank you for your generous tip! Enter a display name to appear on the Supporters Wall, visible to all PommeCore users.": {
      "comment": "A message displayed when the user taps the \"Add My Name\" button in the \"Join the Supporters Wall?\" alert.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vielen Dank für Ihr großzügiges Trinkgeld! Geben Sie einen Anzeigenamen ein, um auf der Unterstützerwand zu erscheinen, die für alle PommeCore-Benutzer sichtbar ist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Merci pour votre généreux pourboire ! Entrez un nom d'affichage pour apparaître sur le Mur des Soutenants, visible par tous les utilisateurs de PommeCore."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Gracias por tu generoso propina! Ingresa un nombre de visualización para aparecer en el Muro de Socios, visible para todos los usuarios de PommeCore."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Grazie per la tua generosa donazione! Inserisci un nome di visualizzazione per apparire sulla parete dei sostenitori, visibile a tutti gli utenti PommeCore."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bedankt voor jouw genereuze tip! Voer een weergavenaam in om te verschijnen op de Supporters Wall, zichtbaar voor alle PommeCore-gebruikers."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Obrigado pelo seu generoso duto! Digite um nome de exibição para aparecer na Parede de Apoiadores, visível a todos os usuários do PommeCore."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Děkujeme za vaši štědrou tip! Zadejte zobrazený název, který se objeví na zdi podporovatelů, viditelný všem uživatelům PommeCore."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dziękujemy za hojne napiwki! Wpisz nazwę wyświetlacza, aby pojawić się na Ścianie Wspierających, widocznej dla wszystkich użytkowników PommeCore."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Дякуємо за ваш щедрий внесок! Введіть ім'я для відображення на Стіні підтримувачів, видиме всім користувачам PommeCore."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "お寛大なチップをありがとうございます！サポートウォールに表示名を入力してください（すべてのPommeCoreユーザーに表示されます）。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "感谢您的慷慨打赏！输入显示名称，在PommeCore用户中可见的支持者墙上出现。"
          }
        }
      }
    },
    "The contact's meshcore:// link has been copied to the clipboard.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der meshcore://-Link des Kontakts wurde in die Zwischenablage kopiert."
          }
        },
        "fr": {
