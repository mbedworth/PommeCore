    "Choose a contact or channel from the sidebar to start messaging.": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte kontakt nebo kanál z bočního panelu pro zahájení zasílání zpráv."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontakt oder Kanal aus der Seitenleiste auswählen, um Nachrichten zu senden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige un contacto o canal desde el panel lateral para empezar a mensajear."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez un contact ou une chaîne dans la barre latérale pour commencer à discuter."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli un contatto o una canale dalla barra laterale per iniziare a messaggiare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サイドバーから連絡先またはチャンネルを選択してメッセージの開始。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies een contact of kanaal uit de zijbalk om te beginnen met chatten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz kontakt lub kanał z bocznego panelu, aby rozpocząć wysyłanie wiadomości."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha um contato ou canal na barra lateral para iniciar a mensagem."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть контакт або канал у бічній панелі, щоб почати обмін повідомленнями."
          }
        },
        "zh-Hans": {
