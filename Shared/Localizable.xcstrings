    "Change default passwords after login via Remote Management → Security.": {
      "comment": "A warning message that appears when the default passwords are changed.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standardpasswörter nach der Anmeldung über Remote-Verwaltung → Sicherheit ändern."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Modifier les mots de passe par défaut après connexion via la gestion à distance → Sécurité."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambiar contraseñas predeterminadas después de iniciar sesión mediante Gestión Remota → Seguridad."
          }
        },
        "it": {
