    "Your radio is connected via USB. Tap the button below to send the command.": {
      "comment": "A message displayed in the firmware update flow.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr Radio ist über USB verbunden. Tippen Sie auf die Schaltfläche unten, um den Befehl zu senden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre radio est connectée via USB. Appuyez sur le bouton ci-dessous pour envoyer la commande."
